---
import '../styles/global.css';

type Props = {
  title: string;
  authenticated?: boolean;
  lockViewport?: boolean;
};

const { title, authenticated = false, lockViewport = false } = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full" data-lock-viewport={lockViewport ? 'true' : undefined}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      try {
        const savedTheme = window.localStorage.getItem('live-chat-theme');
        document.documentElement.dataset.theme = savedTheme === 'light' ? 'light' : 'dark';
      } catch {
        document.documentElement.dataset.theme = 'dark';
      }
    </script>
    <title>{title}</title>
  </head>
  <body class={`antialiased ${lockViewport ? 'h-full overflow-hidden' : 'min-h-full'}`}>
    <div x-data={`liveChatCreateAppShell(${JSON.stringify({ authenticated })})`} x-init="init()" class={lockViewport ? 'flex h-full min-h-0 flex-col' : 'min-h-full'}>
      <slot />

      <div class="pointer-events-none fixed bottom-20 right-4 z-50 flex justify-end sm:bottom-24 sm:right-6">
        <div
          id="global-notification-toast"
          x-cloak
          x-show="notificationOpen"
          x-transition:enter="transform transition ease-out duration-200"
          x-transition:enter-start="translate-y-4 opacity-0"
          x-transition:enter-end="translate-y-0 opacity-100"
          x-transition:leave="transform transition ease-in duration-500"
          x-transition:leave-start="translate-x-0 opacity-100"
          x-transition:leave-end="translate-x-8 opacity-0"
          class="pointer-events-auto w-[clamp(16rem,25vw,24rem)] max-w-[calc(100vw-1.5rem)] sm:max-w-[calc(100vw-3rem)]"
          x-html="notificationHtml"
          aria-live="polite"
          aria-atomic="true"
        ></div>
      </div>

      <div class="pointer-events-none fixed inset-x-0 bottom-4 z-50 flex justify-center px-4 sm:bottom-6">
        <div
          id="global-error-toast"
          x-cloak
          x-show="errorOpen"
          x-transition:enter="transform transition ease-out duration-200"
          x-transition:enter-start="translate-y-4 opacity-0"
          x-transition:enter-end="translate-y-0 opacity-100"
          x-transition:leave="transform transition ease-in duration-500"
          x-transition:leave-start="translate-y-0 opacity-100"
          x-transition:leave-end="translate-y-8 opacity-0"
          class="pointer-events-auto w-full max-w-xl"
          x-html="errorHtml"
          aria-live="polite"
          aria-atomic="true"
        ></div>
      </div>
    </div>

    <script>
      import htmx from 'htmx.org';
      import 'htmx-ext-sse';
      import Alpine from 'alpinejs';

      window.htmx = htmx;

      const createTabId = () => {
        const existing = window.sessionStorage.getItem('live-chat-tab-id');
        if (existing) {
          return existing;
        }

        const nextValue = `${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;
        window.sessionStorage.setItem('live-chat-tab-id', nextValue);
        return nextValue;
      };

      window.liveChatGetTabId = createTabId;
      const profileStorageKey = 'live-chat-profile';

      window.liveChatCreateAppShell = (config) => ({
        authenticated: Boolean(config?.authenticated),
        theme: document.documentElement.dataset.theme === 'light' ? 'light' : 'dark',
        errorHtml: '',
        errorOpen: false,
        errorTimer: null,
        notificationHtml: '',
        notificationOpen: false,
        notificationTimer: null,
        notificationQueue: [],
        htmxErrorListener: null,
        notificationStream: null,
        notificationReconnectTimer: null,

        init() {
          window.liveChatShowError = (html) => this.showError(html);
          window.liveChatShowNotification = (html) => this.queueNotification(html);
          window.liveChatToggleTheme = () => this.toggleTheme();
          this.syncThemeToggleLabels();

          if (this.authenticated) {
            this.initNotificationStream();
          }

          this.htmxErrorListener = (event) => {
            const xhr = event.detail?.xhr;
            const contentType = xhr?.getResponseHeader?.('Content-Type') ?? '';
            const responseText = xhr?.responseText?.trim?.() ?? '';

            if (!xhr || xhr.status < 400 || !contentType.includes('text/html') || !responseText) {
              return;
            }

            event.detail.shouldSwap = false;
            event.detail.isError = false;
            this.showError(responseText);

            const redirect = xhr.getResponseHeader('HX-Redirect');
            if (redirect) {
              window.setTimeout(() => window.location.assign(redirect), 900);
            }
          };

          document.body.addEventListener('htmx:beforeSwap', this.htmxErrorListener);
        },

        destroy() {
          if (this.errorTimer) {
            window.clearTimeout(this.errorTimer);
          }
          if (this.notificationTimer) {
            window.clearTimeout(this.notificationTimer);
          }
          if (this.notificationReconnectTimer) {
            window.clearTimeout(this.notificationReconnectTimer);
          }
          if (this.htmxErrorListener) {
            document.body.removeEventListener('htmx:beforeSwap', this.htmxErrorListener);
          }
          if (this.notificationStream) {
            this.notificationStream.close();
            this.notificationStream = null;
          }
          delete window.liveChatShowError;
          delete window.liveChatShowNotification;
          delete window.liveChatToggleTheme;
        },

        showError(html) {
          this.errorHtml = html;
          this.errorOpen = true;

          if (this.errorTimer) {
            window.clearTimeout(this.errorTimer);
          }

          this.errorTimer = window.setTimeout(() => {
            this.errorOpen = false;
          }, 5000);
        },

        queueNotification(html) {
          const normalizedHtml = typeof html === 'string' ? html.trim() : '';
          if (!normalizedHtml) {
            return;
          }

          this.notificationQueue.push(normalizedHtml);
          if (!this.notificationOpen) {
            this.showNextNotification();
          }
        },

        showNextNotification() {
          const nextHtml = this.notificationQueue.shift();
          if (!nextHtml) {
            this.notificationOpen = false;
            this.notificationHtml = '';
            return;
          }

          this.notificationHtml = nextHtml;
          this.notificationOpen = true;

          if (this.notificationTimer) {
            window.clearTimeout(this.notificationTimer);
          }

          this.notificationTimer = window.setTimeout(() => {
            this.notificationOpen = false;
            this.showNextNotification();
          }, 5000);
        },

        applyTheme(theme) {
          this.theme = theme === 'light' ? 'light' : 'dark';
          document.documentElement.dataset.theme = this.theme;
          try {
            window.localStorage.setItem('live-chat-theme', this.theme);
          } catch {
            // Ignore storage failures and keep the in-memory theme.
          }
          this.syncThemeToggleLabels();
        },

        toggleTheme() {
          this.applyTheme(this.theme === 'light' ? 'dark' : 'light');
        },

        syncThemeToggleLabels() {
          const label = this.theme === 'light' ? '🌙' : '💡';
          document.querySelectorAll('[data-theme-toggle-label]').forEach((node) => {
            node.textContent = label;
          });
        },

        scheduleNotificationReconnect() {
          if (this.notificationReconnectTimer || !this.authenticated) {
            return;
          }

          this.notificationReconnectTimer = window.setTimeout(() => {
            this.notificationReconnectTimer = null;
            this.initNotificationStream();
          }, 1500);
        },

        initNotificationStream() {
          if (this.notificationStream) {
            this.notificationStream.close();
          }

          this.notificationStream = new EventSource('/api/notifications/stream');
          this.notificationStream.addEventListener('open', () => {
            if (this.notificationReconnectTimer) {
              window.clearTimeout(this.notificationReconnectTimer);
              this.notificationReconnectTimer = null;
            }
          });
          this.notificationStream.addEventListener('mention', (event) => {
            this.queueNotification(event.data);
          });
          this.notificationStream.addEventListener('error', () => {
            if (this.notificationStream) {
              this.notificationStream.close();
              this.notificationStream = null;
            }
            this.scheduleNotificationReconnect();
          });
        },
      });

      window.liveChatCreateRoomController = (config) => ({
        roomId: config.roomId,
        nickname: config.nickname,
        nicknameColor: config.nicknameColor,
        profileUpdatePath: config.profileUpdatePath,
        presenceJoinPath: config.presenceJoinPath,
        presenceLeavePath: config.presenceLeavePath,
        typingPath: config.typingPath,
        tabId: '',
        sidebarOpen: false,
        sidebarCollapsed: false,
        historyScrollSnapshot: null,
        typingTimer: null,
        typingThrottleTimer: null,
        mentionOpen: false,
        mentionQuery: '',
        mentionStart: -1,
        mentionEnd: -1,
        mentionResults: [],
        mentionActiveIndex: 0,
        mentionAbortController: null,
        presenceInterval: null,
        activityOpen: false,
        presenceOpen: false,
        profileEditorOpen: false,
        profileDraftNickname: config.nickname,
        profileDraftColor: config.nicknameColor,
        profileSaving: false,
        pageLeaveHandler: null,
        profileStorageListener: null,

        init() {
          this.tabId = createTabId();
          this.sidebarCollapsed = window.matchMedia('(min-width: 1024px)').matches && window.localStorage.getItem('live-chat-sidebar-collapsed') === 'true';
          window.liveChatRoom = this;

          this.$nextTick(() => {
            this.scrollToBottom();
            this.annotatePresenceCard();
          });

          this.joinPresence();
          this.presenceInterval = window.setInterval(() => this.joinPresence(), 20000);

          this.pageLeaveHandler = () => this.leavePresence();
          window.addEventListener('pagehide', this.pageLeaveHandler);
          window.addEventListener('beforeunload', this.pageLeaveHandler);

          this.profileStorageListener = (event) => {
            if (event.key !== profileStorageKey || !event.newValue) {
              return;
            }

            try {
              const payload = JSON.parse(event.newValue);
              if (payload?.nickname && payload?.nicknameColor) {
                this.applyProfile(payload, false);
              }
            } catch {
              // Ignore malformed storage payloads.
            }
          };

          window.addEventListener('storage', this.profileStorageListener);
        },

        destroy() {
          if (this.presenceInterval) {
            window.clearInterval(this.presenceInterval);
          }
          if (this.typingTimer) {
            window.clearTimeout(this.typingTimer);
          }
          if (this.typingThrottleTimer) {
            window.clearTimeout(this.typingThrottleTimer);
          }
          if (this.mentionAbortController) {
            this.mentionAbortController.abort();
          }
          if (this.pageLeaveHandler) {
            window.removeEventListener('pagehide', this.pageLeaveHandler);
            window.removeEventListener('beforeunload', this.pageLeaveHandler);
          }
          if (this.profileStorageListener) {
            window.removeEventListener('storage', this.profileStorageListener);
          }
          this.leavePresence();
        },

        bodyParams() {
          return new URLSearchParams({
            tabId: this.tabId,
          });
        },

        async handleBackgroundResponse(response) {
          if (response.ok) {
            return true;
          }

          const contentType = response.headers.get('content-type') ?? '';
          if (contentType.includes('text/html')) {
            window.liveChatShowError?.(await response.text());
          }

          const redirect = response.headers.get('HX-Redirect');
          if (redirect) {
            window.setTimeout(() => window.location.assign(redirect), 900);
          }

          return false;
        },

        joinPresence() {
          void fetch(this.presenceJoinPath, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
            },
            body: this.bodyParams(),
            credentials: 'same-origin',
          }).then((response) => this.handleBackgroundResponse(response));
        },

        leavePresence() {
          if (!this.tabId) {
            return;
          }

          const payload = this.bodyParams();
          navigator.sendBeacon(
            this.presenceLeavePath,
            new Blob([payload.toString()], { type: 'application/x-www-form-urlencoded;charset=UTF-8' }),
          );
        },

        notifyTyping() {
          const input = this.$refs.messageInput;
          if (!input) {
            return;
          }

          if (!input.value.trim()) {
            this.stopTyping();
            return;
          }

          if (this.typingThrottleTimer) {
            return;
          }

          const submit = () => {
            void fetch(this.typingPath, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
              },
              body: this.bodyParams(),
              credentials: 'same-origin',
            }).then((response) => this.handleBackgroundResponse(response));
            this.typingThrottleTimer = null;
          };

          submit();
          this.typingThrottleTimer = window.setTimeout(() => {
            this.typingThrottleTimer = null;
          }, 1200);

          if (this.typingTimer) {
            window.clearTimeout(this.typingTimer);
          }

          this.typingTimer = window.setTimeout(() => this.stopTyping(), 4200);
        },

        handleComposerInput(event) {
          this.notifyTyping();
          this.updateMentionPicker(event.target);
        },

        handleComposerKeydown(event) {
          if (!this.mentionOpen || this.mentionResults.length === 0) {
            return;
          }

          if (event.key === 'ArrowDown') {
            event.preventDefault();
            this.mentionActiveIndex = (this.mentionActiveIndex + 1) % this.mentionResults.length;
            return;
          }

          if (event.key === 'ArrowUp') {
            event.preventDefault();
            this.mentionActiveIndex = (this.mentionActiveIndex - 1 + this.mentionResults.length) % this.mentionResults.length;
            return;
          }

          if (event.key === 'Enter' || event.key === 'Tab') {
            event.preventDefault();
            this.selectMention(this.mentionResults[this.mentionActiveIndex]);
            return;
          }

          if (event.key === 'Escape') {
            this.closeMentionPicker();
          }
        },

        updateMentionPicker(input) {
          if (!input) {
            this.closeMentionPicker();
            return;
          }

          const beforeCursor = input.value.slice(0, input.selectionStart ?? input.value.length);
          const match = beforeCursor.match(/(^|\\s)@([^\\s\\[]*)$/);

          if (!match) {
            this.closeMentionPicker();
            return;
          }

          this.mentionQuery = match[2] ?? '';
          this.mentionStart = beforeCursor.length - this.mentionQuery.length - 1;
          this.mentionEnd = beforeCursor.length;
          this.fetchMentionResults();
        },

        fetchMentionResults() {
          if (this.mentionAbortController) {
            this.mentionAbortController.abort();
          }

          this.mentionAbortController = new AbortController();
          const params = new URLSearchParams({ roomId: String(this.roomId) });
          if (this.mentionQuery) {
            params.set('q', this.mentionQuery);
          }

          void fetch(`/api/mentions?${params.toString()}`, {
            credentials: 'same-origin',
            signal: this.mentionAbortController.signal,
          })
            .then(async (response) => {
              if (!response.ok) {
                await this.handleBackgroundResponse(response);
                return null;
              }

              return response.json();
            })
            .then((payload) => {
              if (!payload) {
                this.closeMentionPicker();
                return;
              }

              this.mentionResults = payload.nicknames ?? [];
              this.mentionActiveIndex = 0;
              this.mentionOpen = this.mentionResults.length > 0;
            })
            .catch((error) => {
              if (error?.name !== 'AbortError') {
                this.closeMentionPicker();
              }
            });
        },

        selectMention(nickname) {
          const input = this.$refs.messageInput;
          if (!input || !nickname) {
            return;
          }

          const value = input.value;
          const nextValue = `${value.slice(0, this.mentionStart)}@[${nickname}] ${value.slice(this.mentionEnd)}`;
          input.value = nextValue;
          const nextCursor = this.mentionStart + nickname.length + 4;
          input.setSelectionRange(nextCursor, nextCursor);
          this.closeMentionPicker();
          input.focus();
        },

        closeMentionPicker() {
          this.mentionOpen = false;
          this.mentionQuery = '';
          this.mentionResults = [];
          this.mentionActiveIndex = 0;
          this.mentionStart = -1;
          this.mentionEnd = -1;
        },

        stopTyping() {
          if (this.typingTimer) {
            window.clearTimeout(this.typingTimer);
            this.typingTimer = null;
          }

          if (!this.tabId) {
            return;
          }

          void fetch(`${this.typingPath}?stop=1`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
            },
            body: this.bodyParams(),
            credentials: 'same-origin',
          }).then((response) => this.handleBackgroundResponse(response));
        },

        handleComposerAfterRequest(event) {
          if (!event.detail.successful) {
            return;
          }

          this.$refs.composerForm.reset();
          this.closeMentionPicker();
          this.stopTyping();
          this.scrollToBottom(true);
        },

        captureHistoryScroll() {
          const viewport = this.$refs.messageViewport;
          this.historyScrollSnapshot = viewport ? viewport.scrollHeight - viewport.scrollTop : null;
        },

        restoreHistoryScroll() {
          const viewport = this.$refs.messageViewport;
          if (!viewport || this.historyScrollSnapshot === null) {
            return;
          }

          this.$nextTick(() => {
            viewport.scrollTop = viewport.scrollHeight - this.historyScrollSnapshot;
            this.historyScrollSnapshot = null;
          });
        },

        scrollToBottom(force = false) {
          const viewport = this.$refs.messageViewport;
          if (!viewport) {
            return;
          }

          const distanceFromBottom = viewport.scrollHeight - viewport.scrollTop - viewport.clientHeight;
          if (!force && distanceFromBottom > 160) {
            return;
          }

          this.$nextTick(() => {
            viewport.scrollTop = viewport.scrollHeight;
          });
        },

        handleSseSwap(event) {
          const target = event.target;
          if (target?.id === 'message-list') {
            this.scrollToBottom();
            return;
          }

          if (target?.id === 'presence-card') {
            this.annotatePresenceCard();
          }
        },

        toggleSidebarCollapse() {
          this.sidebarCollapsed = !this.sidebarCollapsed;
          window.localStorage.setItem('live-chat-sidebar-collapsed', String(this.sidebarCollapsed));
        },

        sidebarGridStyle() {
          if (!window.matchMedia('(min-width: 1024px)').matches) {
            return '';
          }

          return `grid-template-columns: ${this.sidebarCollapsed ? '84px' : '224px'} minmax(0, 1fr);`;
        },

        annotatePresenceCard() {
          const card = document.getElementById('presence-card');
          if (!card) {
            return;
          }

          card.querySelectorAll('[data-presence-nickname]').forEach((node) => {
            const isYou = node.getAttribute('data-presence-nickname') === this.nickname;
            const badge = node.querySelector('[data-you-badge]');
            if (!badge) {
              return;
            }

            badge.classList.toggle('hidden', !isYou);
          });
        },

        toggleProfileEditor() {
          this.profileDraftNickname = this.nickname;
          this.profileDraftColor = this.nicknameColor;
          this.profileEditorOpen = !this.profileEditorOpen;
        },

        applyProfile(profile, broadcast = true) {
          this.nickname = profile.nickname;
          this.nicknameColor = profile.nicknameColor;
          this.profileDraftNickname = profile.nickname;
          this.profileDraftColor = profile.nicknameColor;
          this.annotatePresenceCard();

          if (!broadcast) {
            return;
          }

          try {
            window.localStorage.setItem(profileStorageKey, JSON.stringify({
              nickname: profile.nickname,
              nicknameColor: profile.nicknameColor,
              updatedAt: Date.now(),
            }));
          } catch {
            // Ignore storage failures and keep in-memory profile state.
          }
        },

        async submitProfileUpdate(event) {
          if (this.profileSaving) {
            return;
          }

          this.profileSaving = true;

          try {
            const formData = new FormData(event.target);
            const body = new URLSearchParams();
            body.set('nickname', String(formData.get('nickname') ?? ''));
            body.set('nicknameColor', String(formData.get('nicknameColor') ?? ''));

            const response = await fetch(this.profileUpdatePath, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
              },
              body,
              credentials: 'same-origin',
            });

            if (!response.ok) {
              await this.handleBackgroundResponse(response);
              return;
            }

            const payload = await response.json();
            this.applyProfile(payload);
            this.profileEditorOpen = false;
          } finally {
            this.profileSaving = false;
          }
        },
      });

      window.Alpine = Alpine;
      Alpine.start();
    </script>
  </body>
</html>
